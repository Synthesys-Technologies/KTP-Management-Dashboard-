# Postgres connection string (Railway provides this when you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "true" only if connecting over a public/SSL Postgres URL.
# For Railway's internal connection, leave as "false".
PGSSL=false

# Shared secret Hermes must send as: Authorization: Bearer <this value>
# Generate a long random string, e.g. `openssl rand -hex 32`
HERMES_API_KEY=replace-with-a-long-random-secret
